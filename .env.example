# Copy to .env and adjust paths for your machine.
# Source before running: set -a && source .env && set +a

# Repository root (auto-detected if unset; set explicitly when using custom layouts)
# REPO_ROOT=/path/to/human-vehicle-sim

# CARLA installation (required for CarlaSim/)
CARLA_ROOT=/path/to/CARLA
CARLA_PYTHONAPI_CARLA=${CARLA_ROOT}/PythonAPI/carla

# PIE dataset root (not in repo — clone https://github.com/aras62/PIE into PIE_dataset/)
PIE_ROOT=${REPO_ROOT:-.}/PIE_dataset

# PIE crossing-intent RF (default: 9-feature heading variant)
PIP_RF_MODEL=${REPO_ROOT:-.}/PedestrianIntentPrediction/pie/models/rf_ma_rong_pie_heading.joblib
# 7-feature paper model (Ma & Rong 2022, no trajectory heading):
# PIP_RF_MODEL=${REPO_ROOT:-.}/PedestrianIntentPrediction/pie/models/rf_ma_rong_pie.joblib
PIP_RF_THRESHOLD=0.5

# YOLO pose weights (place yolov8m-pose.pt in CarlaSim/ or repo root)
YOLO_POSE_MODEL=${REPO_ROOT:-.}/CarlaSim/yolov8m-pose.pt

# Simulation logging
SIM_RUN_LOGGER=1
SIM_CAPTURE_DIR=${REPO_ROOT:-.}/CarlaSim/simulation_captures

# eval_sim batch runner overrides
SIM_SPAWN_PRESETS=eval_sim.spawn_presets
# WALKER_SPAWN_PRESET=nearside_off   # preset name within the spawn module above
